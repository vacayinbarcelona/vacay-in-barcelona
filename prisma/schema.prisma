// Prisma schema for Vacay in Barcelona
// Postgres (e.g. a free Neon project) — required for deploying to Vercel
// or any other serverless host, since SQLite's local file won't persist
// there. Point DATABASE_URL at the same Postgres database for local dev
// too, so there's one schema, one database, no drift between the two.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled (PgBouncer) connection — used by the running app. Neon's free-tier
  // compute auto-suspends after idling; a direct connection left open across
  // that suspend gets dropped ("Server has closed the connection"), but the
  // pooler transparently reconnects/wakes the compute instead of erroring.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection — used only by `prisma db push` / migrate,
  // which don't work reliably through PgBouncer's transaction pooling mode.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Attraction / tour / show — the core content type shown on the homepage
// and on its own detail page at /attractions/[slug]
// ---------------------------------------------------------------------------
model Attraction {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  city        String  @default("Barcelona")
  category    String  @default("attraction") // attraction | tour | show
  categoryLabel String @default("") // display label, e.g. "Architecture & landmarks"
  status      String  @default("published") // draft | published

  badge String @default("") // card ribbon, e.g. "Best seller", "Recommended"

  // Short italic line shown under the H1 on the detail page hero,
  // e.g. "Gaudí's Masterpiece". Optional — hidden if blank.
  tagline String @default("")

  shortDescription String
  longDescription  String // supports simple paragraphs separated by blank lines

  heroImageUrl String
  heroImageAlt String

  rating      Float  @default(4.5)
  reviewCount Int    @default(0)

  priceFrom     Float  @default(0)
  currency      String @default("EUR")

  durationLabel String @default("") // e.g. "2-3 hours", "Flexible"
  freeCancellation Boolean @default(true)
  mobileTicket     Boolean @default(true)

  // If true, checkout collects a first + last name for every traveler
  // (matches the ID/passport shown at entry — e.g. Sagrada Família).
  // If false, checkout only collects a single lead-traveler name.
  requiresAllTravelerNames Boolean @default(false)

  address   String @default("")
  mapUrl    String @default("") // link to a map service, optional

  featured Boolean @default(false) // shown in "Popular Barcelona Attractions"
  popularTour Boolean @default(false) // shown in "Popular Tours & Experiences"
  sortOrder   Int     @default(0)

  metaTitle       String @default("")
  metaDescription String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketOptions TicketOption[]
  highlights    Highlight[]
  includedItems IncludedItem[]
  infoItems     ImportantInfoItem[]
  faqs          FAQ[]
  reviews       Review[]
  images        AttractionImage[]
  quickFacts    QuickFact[]

  // Suppliers granted access to add their own products under this
  // attraction ("category page") — see the Supplier model below.
  supplierCategories SupplierCategory[]
}

// A bookable ticket / tour option belonging to an attraction.
// affiliateUrl is where "Book Now" sends the visitor today; provider/externalId
// are placeholders for wiring up a live booking API later.
model TicketOption {
  id           String @id @default(cuid())
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  name        String // e.g. "Skip-the-Line Entry Ticket"
  description String @default("")

  price    Float
  currency String @default("EUR")

  durationLabel    String  @default("")
  freeCancellation Boolean @default(true)
  mobileTicket     Boolean @default(true)
  instantConfirmation Boolean @default(true)
  languages        String  @default("") // comma-separated, e.g. "English, Spanish"
  groupType        String  @default("") // e.g. "Small group (max 15)"

  badge String @default("") // e.g. "Best seller", "Likely to sell out"

  affiliateUrl      String // external booking link (GetYourGuide/Viator/etc. or your own API later)
  affiliateProvider String @default("") // e.g. "GetYourGuide", "Viator", "Direct API"

  // Manual Supplier Management System (stopgap while Rezdy API access is
  // pending — see the Supplier model's comment for how this is designed to
  // fold into a future Rezdy sync without a redesign). Null supplierId =
  // a "house" product created directly by the Master/editor admin, exactly
  // like every TicketOption before this feature existed — those default to
  // status "published" immediately, same as today. A supplier-created
  // product defaults to "pending_review" and only appears on the public
  // site once a Master Admin approves it.
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  status          String @default("published") // pending_review | published | rejected | disabled
  rejectionReason String @default("") // shown to the supplier when status = rejected

  // Direct contact details for whoever fulfills this specific product —
  // required when a supplier creates/edits a product (see the "required"
  // attribute in ProductForm.tsx and the check in
  // src/app/supplier/(dashboard)/products/actions.ts), optional for house
  // products created by the Master Admin. Shown to the customer after
  // booking (see Booking's snapshot fields below) so they can reach the
  // operator directly about their specific reservation.
  supplierContactEmail String @default("")
  supplierContactPhone String @default("")

  cancellationPolicy String @default("")
  maxGroupSize       Int?

  // Informational only for now — the live booking calendar still uses the
  // demo generator in src/lib/availability.ts until real Rezdy availability
  // is connected (see the TODO there). Comma-separated, e.g.
  // "Mon,Tue,Wed,Thu,Fri" / "09:00,12:30,16:00".
  availableDays String @default("")
  timeSlots     String @default("")

  images TicketOptionImage[]

  // Product-specific details — different for every ticket/tour option (a
  // guided tour meets somewhere different than a plain entry ticket, and
  // each has its own inclusions). Deliberately NOT shown on the public
  // attraction page (which is shared across all of an attraction's
  // products) — only surfaced after booking, on the confirmation page and
  // in the confirmation email (see Booking's snapshot fields below). These
  // are exactly the fields a future Rezdy sync would populate automatically
  // instead of an admin typing them in.
  // Street address only — fed straight into the Google Maps search link on
  // the confirmation page/email (see mapUrl in booking-confirmation and
  // bookingCardHtml in src/lib/email.ts), kept separate from the free-text
  // instructions below so the map query isn't polluted with directions like
  // "look for the blue umbrella".
  meetingPointAddress String @default("")
  meetingPoint         String @default("") // free-text instructions/directions, shown alongside the address — label reads "Meeting Point Instruction" in the admin/supplier UI
  meetingPointImage    String @default("") // URL/path shown alongside the meeting point on the confirmation page & email

  includedItems TicketIncludedItem[]
  infoItems     TicketInfoItem[]

  // Rich availability calendar — language -> date range -> weekday -> time
  // slot -> ticket types (age range/price/inventory). Replaces the legacy
  // availableDays/timeSlots fields above as the editable UI (see
  // AvailabilityScheduleEditor.tsx); those legacy fields are left in place,
  // unused, rather than removed, since nothing reads them today either.
  // NOTE: as of this schema addition, checkout/the public booking flow does
  // NOT yet read this data — only the admin/supplier product forms write
  // it. Wiring it into checkout is a deliberately separate follow-up (see
  // the phase-2 tasks) so this addition can't break live bookings.
  languageSchedules TicketOptionLanguageSchedule[]

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One language's full availability schedule for a product — e.g. "English,
// bookable Aug 1 - Oct 31". A product can have several of these (one per
// language it's offered in), each with its own date range and time slots.
model TicketOptionLanguageSchedule {
  id             String       @id @default(cuid())
  ticketOptionId String
  ticketOption   TicketOption @relation(fields: [ticketOptionId], references: [id], onDelete: Cascade)

  language String
  dateFrom DateTime
  dateTo   DateTime

  slots TicketOptionScheduleSlot[]

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
}

// One weekday + time combination within a language schedule — e.g. "Mon,
// 09:00". Which weekdays are "selected" for a schedule is derived from
// which weekdays have at least one slot here, rather than stored as its own
// separate list.
//
// Inventory is tracked here, at the slot ("departure") level, not per ticket
// type — this is the standard tour/ticketing model: a 09:00 departure has one
// shared pool of seats (e.g. 30 total), and every ticket type booked against
// that departure (Adult/Child/Infant/Senior) draws down the same pool.
// Remaining availability = availability minus the sum of all ticket types'
// quantities booked against this slot across all orders.
model TicketOptionScheduleSlot {
  id                String                       @id @default(cuid())
  languageScheduleId String
  languageSchedule   TicketOptionLanguageSchedule @relation(fields: [languageScheduleId], references: [id], onDelete: Cascade)

  weekday String // "Mon" | "Tue" | "Wed" | "Thu" | "Fri" | "Sat" | "Sun"
  time    String // "HH:MM", 15-minute increments

  availability Int @default(0) // total shared inventory for this departure, across all ticket types

  ticketTypes TicketOptionScheduleTicketType[]

  sortOrder Int @default(0)
}

// One bookable ticket category within a specific time slot — e.g. "Adult,
// 18-64 years, €45". Fully custom per slot: a supplier can rename/add/remove
// these freely, the 4 common ones (Adult/Child/Infant/Senior) are just a UI
// starting suggestion, not enforced by the schema. No availability field here
// on purpose — inventory is shared across all ticket types at the slot level
// (see TicketOptionScheduleSlot.availability above).
model TicketOptionScheduleTicketType {
  id     String                    @id @default(cuid())
  slotId String
  slot   TicketOptionScheduleSlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)

  name String

  ageFromValue Int
  ageFromUnit  String @default("years") // "years" | "months"
  ageToValue   Int
  ageToUnit    String @default("years") // "years" | "months"

  price Float

  sortOrder Int @default(0)
}

// Per-ticket-option "what's included" / "not included" — see meetingPoint
// comment on TicketOption for why this lives here instead of on Attraction.
model TicketIncludedItem {
  id             String       @id @default(cuid())
  ticketOptionId String
  ticketOption   TicketOption @relation(fields: [ticketOptionId], references: [id], onDelete: Cascade)
  text           String
  included       Boolean @default(true) // true = "What's included", false = "Not included"
  sortOrder      Int     @default(0)
}

// Per-ticket-option "before you go" info — see meetingPoint comment on
// TicketOption for why this lives here instead of on Attraction.
model TicketInfoItem {
  id             String       @id @default(cuid())
  ticketOptionId String
  ticketOption   TicketOption @relation(fields: [ticketOptionId], references: [id], onDelete: Cascade)
  text           String
  sortOrder      Int    @default(0)
}

// Per-ticket-option product photos — suppliers upload these for their own
// products; house products fall back to the attraction's own gallery on the
// public page (see src/app/attractions/[slug]/page.tsx) when empty.
model TicketOptionImage {
  id             String       @id @default(cuid())
  ticketOptionId String
  ticketOption   TicketOption @relation(fields: [ticketOptionId], references: [id], onDelete: Cascade)
  url            String
  altText        String @default("")
  sortOrder      Int    @default(0)
}

model Highlight {
  id           String @id @default(cuid())
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  text         String
  sortOrder    Int    @default(0)
}

model IncludedItem {
  id           String @id @default(cuid())
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  text         String
  included     Boolean @default(true) // true = "What's included", false = "Not included"
  sortOrder    Int    @default(0)
}

model ImportantInfoItem {
  id           String @id @default(cuid())
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  text         String
  sortOrder    Int    @default(0)
}

model FAQ {
  id           String @id @default(cuid())
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  question     String
  answer       String
  sortOrder    Int    @default(0)
}

model Review {
  id           String @id @default(cuid())
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  authorName    String
  authorCountry String   @default("")
  rating        Int      @default(5)
  title         String   @default("")
  comment       String
  visitDate     DateTime @default(now())
  sortOrder     Int      @default(0)

  createdAt DateTime @default(now())
}

model AttractionImage {
  id           String @id @default(cuid())
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  url          String
  altText      String @default("")
  sortOrder    Int    @default(0)
}

// The dark "quick facts" strip at the bottom of the detail page hero, e.g.
// "Built over 140 years / Still under construction". icon is a fixed key
// (see ICON_MAP in QuickFactsStrip.tsx) rather than free text, so it always
// renders a real icon.
model QuickFact {
  id           String @id @default(cuid())
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  icon         String @default("landmark") // column | landmark | people | camera
  title        String
  subtitle     String @default("")
  sortOrder    Int    @default(0)
}

// ---------------------------------------------------------------------------
// A customer account. Optional — checkout still works as a guest without
// signing in (Order.userId is nullable). When a signed-in customer checks
// out, their order is linked here so it shows up in their order history;
// orders placed as a guest with the same email also surface there (see
// /account/orders) even without the userId link.
// ---------------------------------------------------------------------------
model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String? // null for accounts created via "Continue with Google" that never set a password
  googleId     String? @unique // Google "sub" claim, set once they sign in with Google

  // Password sign-ups must click the link in a confirmation email before
  // they can sign in — see /account/verify-email. Google sign-ups are
  // created with this already true, since Google has already verified
  // that email address.
  emailVerified Boolean @default(false)

  // Cooldown for the "resend confirmation email" button (see
  // resendVerificationEmail in check-email/actions.ts) — persisted here
  // rather than kept in memory, so the 60-second cooldown holds even across
  // different serverless instances, preventing it being looped to
  // email-bomb this address.
  lastVerificationEmailSentAt DateTime?

  firstName   String
  lastName    String
  phone       String    @default("")
  dateOfBirth DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

// ---------------------------------------------------------------------------
// An Order is one checkout — one payment, one confirmation email — that can
// contain several Bookings (different attractions/tours/dates added to the
// cart before paying once). This is the record the customer-facing
// reference (e.g. "VIB-7K2P9Q") and the confirmation page are keyed on.
// paymentIntentId is a placeholder for when a real payment provider (e.g.
// Stripe) replaces the demo card fields in checkout.
// ---------------------------------------------------------------------------
model Order {
  id        String @id @default(cuid())
  reference String @unique // human-facing code shown to the customer, e.g. "VIB-7K2P9Q"

  userId String? // set when a signed-in customer checked out; null for guest checkout
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  email         String
  leadFirstName String
  leadLastName  String
  phone         String @default("")

  totalPrice Float
  currency   String @default("EUR")

  status String @default("pending") // pending | confirmed | cancelled

  paymentIntentId         String    @default("") // set once a real payment provider charge is created
  confirmationEmailSentAt DateTime?

  // Self-service cancellation (see /account/orders). refundEligible is
  // computed at cancellation time from each attraction's freeCancellation
  // flag plus a 24-hour-before-visit cutoff. Actual refund money movement
  // isn't wired up yet — there's no real Stripe charge behind
  // paymentIntentId yet either — so this records the outcome for now and
  // an admin processes the real refund manually via Stripe until that's
  // automated (see the TODO in orders/actions.ts).
  cancellationReason String    @default("")
  refundEligible     Boolean?
  cancelledAt        DateTime?

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One line item within an Order — a single ticket/tour selection (one
// attraction, one ticket option, one date/time). rezdyBookingId is a
// placeholder for when real Rezdy availability/booking is connected —
// until then, bookings here are not backed by a real reservation.
model Booking {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  attractionSlug   String
  attractionName   String
  ticketOptionId   String @default("") // the TicketOption this was booked from, when known
  ticketOptionName String

  // Snapshot of that ticket option's product-specific details, copied in at
  // booking time (see createOrder in src/app/checkout/actions.ts). Frozen
  // on purpose — if the product's info is edited later (or re-synced from
  // Rezdy), past customers' confirmations should still show what was true
  // when they booked, not the updated version. Each is newline-separated,
  // one item per line (empty string = nothing to show).
  meetingPointAddress String @default("")
  meetingPoint        String @default("")
  meetingPointImage   String @default("")
  includedSnapshot    String @default("")
  notIncludedSnapshot String @default("")
  beforeYouGoSnapshot String @default("")

  // Which supplier fulfilled this booking, frozen at checkout time (empty
  // string = house product). Lets the Master Admin see supplier attribution
  // on /admin/bookings without joining back through TicketOption, which may
  // later be edited, reassigned, or removed.
  supplierId   String @default("")
  supplierName String @default("")

  // Direct contact details for the supplier who fulfilled this booking,
  // frozen from the TicketOption at checkout time (same reasoning as the
  // other snapshot fields above — a later edit to the product shouldn't
  // change what a past customer sees). Shown on the booking confirmation
  // page and email so the customer can reach the supplier directly about
  // this specific reservation.
  supplierContactEmail String @default("")
  supplierContactPhone String @default("")

  bookingDate DateTime // the visit date selected
  timeSlot    String // e.g. "12:30"
  language    String @default("")

  adults   Int @default(1)
  children Int @default(0)

  pricePerAdult Float
  pricePerChild Float @default(0)
  totalPrice    Float
  currency      String @default("EUR")

  status String @default("pending") // pending | confirmed | cancelled

  rezdyBookingId String @default("") // set once a real Rezdy booking is created

  travelers BookingTraveler[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One row per traveler name, only populated when the attraction has
// requiresAllTravelerNames = true (see Attraction model).
model BookingTraveler {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  type      String @default("adult") // adult | child
  sortOrder Int    @default(0)
}

// ---------------------------------------------------------------------------
// Supplier Management System — the manual stopgap while Rezdy API access is
// pending. A Supplier applies via the public /become-a-supplier form,
// a Master Admin approves/rejects the application and grants access to one
// or more Attraction "category pages" (see SupplierCategory below), and the
// approved supplier logs into their own panel to create/manage TicketOption
// products under those categories only.
//
// Forward-compatible with Rezdy on purpose: a TicketOption doesn't care
// whether it was typed in by a supplier or synced from Rezdy — it's just a
// row with a supplierId, a status, and the same product fields either way.
// When Rezdy access arrives, a sync job can create/update TicketOptions the
// same way this manual panel does, without changing the public site,
// checkout, or the Attraction "category" structure at all.
// ---------------------------------------------------------------------------
model Supplier {
  id String @id @default(cuid())

  companyName String
  contactName String
  email       String @unique
  phone       String @default("")
  website     String @default("")

  // Business verification details, collected on the application form.
  taxId             String @default("") // company tax ID / business registration number
  registeredCountry String @default("") // country where the company is legally registered

  // Why they want to join / what they offer — filled in on the application
  // form, shown to the Master Admin on the review page.
  message String @default("")

  // Set when the applicant checks "I have read the supplier terms &
  // conditions and privacy policy" — required to submit the form (see
  // submitSupplierApplication in src/app/become-a-supplier/actions.ts).
  // Timestamped rather than a plain boolean so there's a record of *when*
  // they agreed, not just that they did.
  termsAcceptedAt DateTime?

  // pending (just applied) -> approved | rejected, set by the Master Admin.
  // An approved supplier can later be disabled (blocks login + hides every
  // one of their products from the public site) without losing their
  // application history.
  status          String    @default("pending") // pending | approved | rejected | disabled
  rejectionReason String    @default("")
  reviewedAt      DateTime?

  // Null until they set a password via the link in the "Supplier Account
  // Approved" email — see createSupplierPasswordSetupToken in
  // src/lib/supplierAuth.ts. Login is blocked with no passwordHash set.
  passwordHash String?

  categories SupplierCategory[]
  products   TicketOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Which Attraction "category pages" a supplier applied for / is allowed to
// manage products under — the same table serves both purposes. A row here
// means "this supplier can create/edit TicketOptions under this Attraction."
// The Master Admin edits this set from /admin/suppliers/[id], defaulting to
// whatever the supplier originally applied for.
model SupplierCategory {
  id           String     @id @default(cuid())
  supplierId   String
  supplier     Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([supplierId, attractionId])
}

// ---------------------------------------------------------------------------
// Additional admin panel logins beyond the one bootstrap "master" account
// defined by ADMIN_EMAIL/ADMIN_PASSWORD in .env (that env-var account
// always works and always has master rights, so the panel can never be
// locked out). Accounts created here from /admin/team can be "master"
// (full access) or "editor" (attractions content + SEO only) — see the
// role checks in each admin page/action.
// ---------------------------------------------------------------------------
model AdminUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  role         String @default("editor") // "master" | "editor"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Simple key/value settings editable from the admin panel — currently used
// for per-page SEO title/description overrides (homepage + the static legal
// pages; attraction pages have their own metaTitle/metaDescription columns
// on the Attraction model instead). Each row is looked up by `key`, e.g.
// "seo.home.title" — `id` just needs to be a normal unique row id.
// ---------------------------------------------------------------------------
model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ---------------------------------------------------------------------------
// Admin-managed header/footer navigation links — editable from
// /admin/nav-links instead of being hardcoded in the Header/Footer
// components. `location` is "header" or "footer"; links within each are
// shown in `sortOrder` order.
// ---------------------------------------------------------------------------
model NavLink {
  id        String @id @default(cuid())
  location  String // "header" | "footer"
  label     String
  href      String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Blog — content-marketing articles ("Things to Do in Barcelona", etc.),
// separate from the Attraction catalogue. `content` is Markdown, rendered
// via src/lib/markdown.ts (supports headings, images, and custom
// :::tip / :::info / :::warning callout blocks). `category` is a free-form
// string rather than its own model — see BLOG_CATEGORIES in
// src/lib/blogCategories.ts for the fixed list offered in the admin panel;
// this mirrors how Attraction.category/categoryLabel already work elsewhere
// in this app, so there's no extra CRUD section just for taxonomy.
// ---------------------------------------------------------------------------
model BlogPost {
  id      String @id @default(cuid())
  slug    String @unique
  title   String
  excerpt String @default("") // shown on cards + used as the meta description fallback; auto-derived from content if left blank

  content String // Markdown

  featuredImageUrl String @default("")
  featuredImageAlt String @default("")

  authorName     String @default("Vacay in Barcelona Team")
  authorImageUrl String @default("")

  category String @default("Things To Do")

  // Drafts are only visible in the admin panel; the public /blog pages only
  // ever show status = "published". publishedAt is set the first time a
  // post is published and then left alone (even if unpublished and
  // republished later), so "originally published" date stays stable.
  status      String    @default("draft") // "draft" | "published"
  publishedAt DateTime?

  metaTitle       String @default("")
  metaDescription String @default("")

  sortOrder Int @default(0) // manual tie-breaker only — the public listing sorts by publishedAt desc

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Newsletter signups from the blog article page's CTA. Deliberately minimal
// — no admin UI to manage subscribers yet (that's a "connect to an ESP like
// Mailchimp/Resend Audiences" job for later); this just captures the email
// so nothing is lost.
// ---------------------------------------------------------------------------
model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
