# Prisma / database
# Local dev (SQLite, zero setup):
DATABASE_URL="file:./dev.db"
# Production example (Postgres, e.g. Neon/Supabase/Vercel Postgres):
# DATABASE_URL="postgresql://user:password@host:5432/vacayinbarcelona"

# Admin panel (CMS) login
ADMIN_EMAIL="you@vacayinbarcelona.com"
ADMIN_PASSWORD="change-this-password"

# Random long random string used to sign admin session cookies.
# Generate one with: openssl rand -hex 32
SESSION_SECRET="replace-with-a-long-random-string"

# Public site URL (used for SEO metadata + sitemap)
NEXT_PUBLIC_SITE_URL="https://vacayinbarcelona.com"

# "Continue with Google" customer sign-in — from Google Cloud Console
# (APIs & Services > Credentials > OAuth client ID > Web application).
# Authorized redirect URI must be: <your-site-url>/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# reCAPTCHA v2 ("I'm not a robot" checkbox) on sign-up/sign-in — from
# https://www.google.com/recaptcha/admin. Add your production domain to
# the site's domain list.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Transactional email (booking confirmations, account verification) via
# Resend — https://resend.com. Verify a *subdomain* (e.g.
# mail.vacayinbarcelona.com), not the root domain, to protect the root
# domain's reputation — see Resend's own recommendation on this.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Vacay in Barcelona <bookings@mail.vacayinbarcelona.com>"

# Rezdy API (real-time availability + booking creation) — added once the
# checkout flow is connected to live tour operator inventory.
# REZDY_API_KEY=""

# Payment provider (e.g. Stripe) — added once real payment collection replaces
# the placeholder card fields in checkout.
# STRIPE_SECRET_KEY=""
